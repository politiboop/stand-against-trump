---
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Documented. Sourced. Undeniable.' } = Astro.props;
const fullTitle = title === 'Home' ? 'Stand Against Trump' : `${title} — Stand Against Trump`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />

  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="article" />
  <meta property="og:image" content="/logo.jpg" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="/logo.jpg" />

  <link rel="alternate" type="application/rss+xml" title="Stand Against Trump" href="/rss.xml" />
  <link rel="icon" href="/logo.jpg" type="image/jpeg" />
  <link rel="apple-touch-icon" href="/logo.jpg" />

  <style>
    @import url('@fontsource/source-serif-4/400.css');
    @import url('@fontsource/source-serif-4/600.css');
    @import url('@fontsource/source-serif-4/700.css');
    @import url('@fontsource/inter/400.css');
    @import url('@fontsource/inter/500.css');
    @import url('@fontsource/inter/600.css');
    @import url('@fontsource/ibm-plex-mono/400.css');
  </style>

  <Analytics />
</head>
<body>
  <header class="site-header">
    <div class="header-inner container-wide">
      <a href="/" class="site-logo">
        <div class="logo-text">
          <span class="logo-the">Stand Against</span>
          <span class="logo-name">Trump</span>
        </div>
      </a>
      <nav class="site-nav">
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/rss.xml" class="rss-link" title="RSS Feed">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><circle cx="6.18" cy="17.82" r="2.18"/><path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/></svg>
        </a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container-wide">
      <p class="footer-tagline">Documented. Sourced. Undeniable.</p>
      <p class="footer-meta">Every claim backed by court records, government filings, and investigative reporting.</p>
      <p class="footer-rss"><a href="/rss.xml">RSS Feed</a></p>
    </div>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  .site-header {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .site-logo {
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .logo-img {
    border-radius: 6px;
    display: block;
  }

  .logo-text {
    display: flex;
    align-items: baseline;
    gap: 5px;
  }

  .logo-the {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--muted);
  }

  .logo-name {
    font-family: var(--font-headline);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text);
  }

  .site-nav {
    display: flex;
    gap: 24px;
  }

  .site-nav a {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .rss-link {
    display: flex;
    align-items: center;
  }

  .rss-link svg {
    opacity: 0.5;
    transition: opacity 0.15s;
  }

  .rss-link:hover svg {
    opacity: 1;
    color: var(--accent);
  }

  .footer-rss {
    margin-top: 8px;
  }

  .footer-rss a {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
  }

  .footer-rss a:hover {
    color: var(--accent);
  }

  .site-nav a:hover {
    color: var(--text);
  }

  .site-footer {
    border-top: 1px solid var(--border);
    padding: 48px 24px;
    margin-top: 80px;
    text-align: center;
  }

  .footer-tagline {
    font-family: var(--font-headline);
    font-size: 1.1rem;
    color: var(--text);
    margin-bottom: 0.3em;
  }

  .footer-meta {
    font-size: 0.8rem;
    color: var(--muted);
  }
</style>
