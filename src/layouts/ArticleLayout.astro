---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  sources?: number;
  readTime?: string;
  date?: string;
}

const { title, description, sources, readTime, date } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="article">
    <header class="article-header">
      <div class="container">
        <a href="/" class="back-link">&larr; All explainers</a>
        <h1>{title}</h1>
        <p class="article-desc">{description}</p>
        <div class="article-meta">
          {sources && <span>{sources} sources cited</span>}
          {readTime && <span>{readTime} read</span>}
          {date && <span>Updated {date}</span>}
        </div>
      </div>
    </header>

    <div class="article-body container">
      <slot />
    </div>

    <footer class="article-footer container">
      <div class="source-notice">
        <p><strong>Every claim in this article links to official records, court documents, or investigative reporting.</strong> If you find an error, we want to know — accuracy is everything. <a href="/about">Learn how we work.</a></p>
      </div>
      <a href="/" class="back-link">&larr; Back to all explainers</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .article-header {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 48px 24px 40px;
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 20px;
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .article-header h1 {
    font-size: 2.2rem;
    max-width: var(--container);
    line-height: 1.15;
  }

  .article-desc {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin-top: 12px;
    max-width: var(--container);
    line-height: 1.6;
    font-style: italic;
  }

  .article-meta {
    display: flex;
    gap: 20px;
    margin-top: 16px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--muted);
  }

  .article-body {
    padding-top: 48px;
    padding-bottom: 48px;
  }

  .article-body :global(h2) {
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }

  .article-body :global(h3) {
    color: var(--accent-dark);
  }

  .article-footer {
    padding: 48px 24px;
    border-top: 1px solid var(--border);
  }

  .source-notice {
    background: var(--accent-light);
    border-left: 3px solid var(--accent);
    padding: 20px 24px;
    border-radius: 0 6px 6px 0;
    margin-bottom: 24px;
  }

  .source-notice p {
    font-size: 0.9rem;
    margin: 0;
    color: var(--text-secondary);
  }

  @media (max-width: 600px) {
    .article-header { padding: 32px 24px; }
    .article-header h1 { font-size: 1.7rem; }
    .article-meta { flex-wrap: wrap; gap: 12px; }
  }
</style>
